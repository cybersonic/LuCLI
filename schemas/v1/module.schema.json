{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lucli.dev/schemas/v1/module.schema.json",
  "title": "LuCLI Module Metadata",
  "description": "Metadata file for LuCLI modules (module.json).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "description": "Module name. Typically matches the module directory name."
    },
    "version": {
      "type": "string",
      "description": "Module version string (e.g. '1.0.0')."
    },
    "description": {
      "type": "string",
      "description": "Short description of the module."
    },
    "author": {
      "type": "string",
      "description": "Author name or identifier."
    },
    "license": {
      "type": "string",
      "description": "License identifier (e.g. 'MIT', 'Apache-2.0')."
    },
    "keywords": {
      "type": "array",
      "description": "Keywords that describe the module.",
      "items": {
        "type": "string"
      }
    },
    "main": {
      "type": "string",
      "description": "Entry file for the module (typically 'Module.cfc').",
      "default": "Module.cfc"
    },
    "created": {
      "type": "string",
      "description": "Creation timestamp for the module (ISO-8601).",
      "format": "date-time"
    },
    "envVars": {
      "type": "array",
      "description": "Shortcut list of environment aliases required by this module.",
      "items": {
        "type": "string"
      }
    },
    "secrets": {
      "type": "array",
      "description": "Shortcut list of secret aliases required by this module.",
      "items": {
        "type": "string"
      }
    },
    "permissions": {
      "type": "object",
      "description": "Declared runtime inputs required by the module.",
      "additionalProperties": false,
      "properties": {
        "env": {
          "type": "array",
          "description": "Environment values requested by the module.",
          "items": {
            "$ref": "#/definitions/permissionEntry"
          },
          "default": []
        },
        "secrets": {
          "type": "array",
          "description": "Secret values requested by the module.",
          "items": {
            "$ref": "#/definitions/permissionEntry"
          },
          "default": []
        }
      }
    }
  },
  "definitions": {
    "permissionEntry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "alias": {
          "type": "string",
          "description": "Stable alias used by module code."
        },
        "required": {
          "type": "boolean",
          "description": "Whether this input is required at runtime.",
          "default": false
        },
        "description": {
          "type": "string",
          "description": "Human-readable description shown during permission prompts."
        }
      },
      "required": [
        "alias"
      ]
    }
  },
  "required": [
    "name",
    "version",
    "description",
    "main"
  ]
}
